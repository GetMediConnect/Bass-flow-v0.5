# ─── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ─────────────────
DATABASE_URL="postgresql://bassflow:bassflow_dev@localhost:5432/bassflow?schema=public"
DIRECT_URL="postgresql://bassflow:bassflow_dev@localhost:5432/bassflow?schema=public"

# ─── Supabase (Storage for audio/covers) ────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_BUCKET_AUDIO="audio"
SUPABASE_BUCKET_COVERS="covers"

# ─── JWT ────────────────────────────────────────────
JWT_SECRET="change-me-use-openssl-rand-hex-64"
JWT_EXPIRES_IN="7d"

# ─── CORS ─────────────────────────────────────────
WEB_URL="http://localhost:8080"
